# Public (browser + server) — required for auth, dashboard, and RLS queries.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Optional: local admin scripts only — the Next.js app uses Supabase Auth + RLS, not the service role.
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Vercel: add the two NEXT_PUBLIC_* vars in Project Settings → Environment Variables
# (Production + Preview). After deploy, in Supabase → Authentication → URL configuration:
#   Site URL:           https://YOUR_PROJECT.vercel.app
#   Redirect URLs:      https://YOUR_PROJECT.vercel.app/auth/callback
#   (for preview deployments, add each preview URL + /auth/callback in Supabase Redirect URLs)
